parameters:
	level: 8

	paths:
		- src

	excludePaths:
		- src/compatibility.php

	ignoreErrors:
		-   # Intentional design pattern for derive() and factory methods
			identifier: new.static
			count: 1
			path: src/Caching/Cache.php
		-   # Intentional design pattern for cache node extensibility
			identifier: new.static
			count: 1
			path: src/Bridges/CacheLatte/Nodes/CacheNode.php

		-   # Intentional by-reference parameter for dependency injection, passed to generator closures via spread
			identifier: argument.byRef
			count: 3
			path: src/Caching/Cache.php

		-   # Runtime validation for untyped array input
			identifier: function.alreadyNarrowedType
			count: 1
			path: src/Caching/Cache.php

		-   # PHPStan cannot narrow callable to array shape after is_array() in closure
			identifier: offsetAccess.nonOffsetAccessible
			count: 1
			path: src/Caching/Cache.php

		-   # Intentional: API for invoking arbitrary user callbacks, a signature would only add false positives at call sites
			identifier: missingType.callable
			count: 3
			path: src/Caching/Cache.php

		-   # BC aliases (IStorage, IBulkReader, IJournal) live in excluded compatibility.php, so PHPStan cannot see them;
			# the class_exists() calls eagerly trigger alias registration when the new interface is loaded
			identifier: function.impossibleType
			message: '#^Call to function class_exists\(\) with ''[^'']+'' will always evaluate to false\.$#'
			paths:
				- src/Caching/Storage.php
				- src/Caching/BulkReader.php
				- src/Caching/Storages/Journal.php
